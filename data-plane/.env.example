APP_HOST=0.0.0.0
APP_PORT=8001
APP_ENV=development

DATABASE_URL=sqlite:///./data/data_plane.db

STORAGE_BASE_PATH=./storage
TRANSCRIPTS_PATH=./storage/transcripts
RECORDINGS_PATH=./storage/recordings

CONTROL_PLANE_URL=http://localhost:8000
CONTROL_PLANE_API_KEY=change-me-in-production
CONFIG_CACHE_TTL_SEC=300

DEEPGRAM_API_KEY=your-deepgram-api-key
DEEPGRAM_STT_MODEL=nova-2
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_STT_LANGUAGE=en-US

CEREBRAS_API_KEY=your-cerebras-api-key
CEREBRAS_MODEL=llama-4-scout-17b-16e-instruct
CEREBRAS_MAX_TOKENS=512
CEREBRAS_TEMPERATURE=0.4

MAX_CALL_DURATION_SEC=600
SILENCE_TIMEOUT_SEC=10
SESSION_TOKEN_TTL_SEC=300
MAX_CONCURRENT_CALLS=50

CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

LOG_LEVEL=INFO
